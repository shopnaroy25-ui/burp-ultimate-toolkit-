APP_ENV=production
APP_DEBUG=false
APP_URL=https://burp-ultimate-toolkit.onrender.com

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=burp
DB_USERNAME=burp
DB_PASSWORD=burp_secure_pass

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

SSL_CERT_PATH=/app/backend/storage/certs
LOG_PATH=/app/logs/app.log

PROXY_PORT=8080
WEBSOCKET_PORT=8443

INTERCEPT_ENABLED=true
MAX_THREADS=100
REQUEST_TIMEOUT=30

JWT_SECRET=super_secret_jwt_key_32_chars_minimum
API_KEY=burp_api_key_2024_secure

CORS_ALLOWED_ORIGINS=*
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_TIME=60

OTP_BRUTE_FORCE_MAX=999999
AI_PREDICTION_ENABLED=true
AUTO_EXPLOIT_ENABLED=false

LOG_LEVEL=info
