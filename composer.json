{
    "name": "burp/ultimate-toolkit",
    "description": "Professional BurpSuite-like Security Testing Toolkit",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-redis": "*",
        "ext-swoole": "*",
        "ext-pdo": "*",
        "ext-pdo_pgsql": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-bcmath": "*",
        "firebase/php-jwt": "^6.0",
        "monolog/monolog": "^3.5",
        "vlucas/phpdotenv": "^5.6",
        "guzzlehttp/guzzle": "^7.8",
        "ramsey/uuid": "^4.7",
        "symfony/cache": "^6.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "autoload": {
        "psr-4": {
            "Burp\\": "backend/core/"
        }
    },
    "scripts": {
        "post-install-cmd": [
            "@php -r \"if (!file_exists('backend/storage')) mkdir('backend/storage', 0777, true);\"",
            "@php -r \"if (!file_exists('backend/storage/certs')) mkdir('backend/storage/certs', 0777, true);\"",
            "@php -r \"if (!file_exists('backend/storage/logs')) mkdir('backend/storage/logs', 0777, true);\""
        ]
    }
}
